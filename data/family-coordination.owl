<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xml:base="http://cognee.test/family"
    xmlns="http://cognee.test/family#">

  <owl:Ontology rdf:about="http://cognee.test/family">
    <rdfs:label>Cognee Load Theory Family Coordination Ontology</rdfs:label>
    <rdfs:comment>
      A small extendable ontology for representing family context, mental load,
      tasks, ownership, dependencies, input sources, and school-start coordination.
    </rdfs:comment>
  </owl:Ontology>

  <!-- Classes -->

  <owl:Class rdf:about="#Family"/>
  <owl:Class rdf:about="#Person"/>
  <owl:Class rdf:about="#Adult">
    <rdfs:subClassOf rdf:resource="#Person"/>
  </owl:Class>
  <owl:Class rdf:about="#Child">
    <rdfs:subClassOf rdf:resource="#Person"/>
  </owl:Class>

  <owl:Class rdf:about="#Place"/>
  <owl:Class rdf:about="#School">
    <rdfs:subClassOf rdf:resource="#Place"/>
  </owl:Class>

  <owl:Class rdf:about="#Event"/>
  <owl:Class rdf:about="#SchoolEvent">
    <rdfs:subClassOf rdf:resource="#Event"/>
  </owl:Class>
  <owl:Class rdf:about="#SchoolStartEvent">
    <rdfs:subClassOf rdf:resource="#SchoolEvent"/>
  </owl:Class>

  <owl:Class rdf:about="#Task"/>
  <owl:Class rdf:about="#Reminder"/>
  <owl:Class rdf:about="#Topic"/>
  <owl:Class rdf:about="#SourceRecord"/>
  <owl:Class rdf:about="#InputChannel"/>
  <owl:Class rdf:about="#MemoryChangeSet"/>
  <owl:Class rdf:about="#OpenLoop"/>
  <owl:Class rdf:about="#LoadCluster"/>

  <!-- Object properties -->

  <owl:ObjectProperty rdf:about="#hasMember">
    <rdfs:domain rdf:resource="#Family"/>
    <rdfs:range rdf:resource="#Person"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#memberOfFamily">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range rdf:resource="#Family"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#parentOf">
    <rdfs:domain rdf:resource="#Adult"/>
    <rdfs:range rdf:resource="#Child"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#siblingOf">
    <rdfs:domain rdf:resource="#Child"/>
    <rdfs:range rdf:resource="#Child"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#livesIn">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range rdf:resource="#Place"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#attendsSchool">
    <rdfs:domain rdf:resource="#Child"/>
    <rdfs:range rdf:resource="#School"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasEvent">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range rdf:resource="#Event"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#takesPlaceAt">
    <rdfs:domain rdf:resource="#Event"/>
    <rdfs:range rdf:resource="#Place"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#affectsPerson">
    <rdfs:domain rdf:resource="#Event"/>
    <rdfs:range rdf:resource="#Person"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#createsTask">
    <rdfs:domain rdf:resource="#Event"/>
    <rdfs:range rdf:resource="#Task"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#ownsTask">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range rdf:resource="#Task"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#suggestedOwner">
    <rdfs:domain rdf:resource="#Task"/>
    <rdfs:range rdf:resource="#Person"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#dependsOn">
    <rdfs:domain rdf:resource="#Task"/>
    <rdfs:range rdf:resource="#Task"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#dueBefore">
    <rdfs:domain rdf:resource="#Task"/>
    <rdfs:range rdf:resource="#Event"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasReminder">
    <rdfs:domain rdf:resource="#Task"/>
    <rdfs:range rdf:resource="#Reminder"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasTopic">
    <rdfs:domain rdf:resource="#Task"/>
    <rdfs:range rdf:resource="#Topic"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#belongsToLoadCluster">
    <rdfs:domain rdf:resource="#Task"/>
    <rdfs:range rdf:resource="#LoadCluster"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#derivedFromSource">
    <rdfs:domain rdf:resource="#Task"/>
    <rdfs:range rdf:resource="#SourceRecord"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#sourceChannel">
    <rdfs:domain rdf:resource="#SourceRecord"/>
    <rdfs:range rdf:resource="#InputChannel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#producedChangeSet">
    <rdfs:domain rdf:resource="#SourceRecord"/>
    <rdfs:range rdf:resource="#MemoryChangeSet"/>
  </owl:ObjectProperty>

  <!-- Datatype properties -->

  <owl:DatatypeProperty rdf:about="#name">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#dateOfBirth">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#age">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#label">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#startDateTime">
    <rdfs:domain rdf:resource="#Event"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#endDateTime">
    <rdfs:domain rdf:resource="#Event"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#taskStatus">
    <rdfs:domain rdf:resource="#Task"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#urgency">
    <rdfs:domain rdf:resource="#Task"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#needsOwner">
    <rdfs:domain rdf:resource="#Task"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#confidence">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#rawText">
    <rdfs:domain rdf:resource="#SourceRecord"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#remindAt">
    <rdfs:domain rdf:resource="#Reminder"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#notificationChannel">
    <rdfs:domain rdf:resource="#Reminder"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <!-- Individuals: family -->
  <!--
    Individuals are declared with an explicit owl:NamedIndividual rdf:type plus
    a class rdf:type. Cognee's RDFLibOntologyResolver collects individuals via
    owl:NamedIndividual; the abbreviated "<ClassName rdf:about=...>" form is not
    reliably picked up, so use the canonical form here.
    The rdfs:label is what entity text is fuzzy-matched against — keep labels
    aligned with how the data is phrased in the ingested sentences.
  -->

  <owl:NamedIndividual rdf:about="#Family_Mertens">
    <rdf:type rdf:resource="#Family"/>
    <rdfs:label>Mertens family</rdfs:label>
    <hasMember rdf:resource="#Vera_Mertens"/>
    <hasMember rdf:resource="#Christian_Mertens"/>
    <hasMember rdf:resource="#Lara_Mertens"/>
    <hasMember rdf:resource="#Paul_Mertens"/>
    <hasMember rdf:resource="#Lila_Mertens"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Bernau_bei_Berlin">
    <rdf:type rdf:resource="#Place"/>
    <rdfs:label>Bernau bei Berlin</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Biesenthal">
    <rdf:type rdf:resource="#Place"/>
    <rdfs:label>Biesenthal</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Grundschule_Biesenthal">
    <rdf:type rdf:resource="#School"/>
    <rdfs:label>Grundschule Biesenthal</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Vera_Mertens">
    <rdf:type rdf:resource="#Adult"/>
    <rdfs:label>Vera Mertens</rdfs:label>
    <name>Vera Mertens</name>
    <dateOfBirth rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1985-04-18</dateOfBirth>
    <memberOfFamily rdf:resource="#Family_Mertens"/>
    <livesIn rdf:resource="#Bernau_bei_Berlin"/>
    <parentOf rdf:resource="#Lara_Mertens"/>
    <parentOf rdf:resource="#Paul_Mertens"/>
    <parentOf rdf:resource="#Lila_Mertens"/>
    <ownsTask rdf:resource="#Task_Confirm_Ceremony_Time"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Christian_Mertens">
    <rdf:type rdf:resource="#Adult"/>
    <rdfs:label>Christian Mertens</rdfs:label>
    <name>Christian Mertens</name>
    <dateOfBirth rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1982-11-02</dateOfBirth>
    <memberOfFamily rdf:resource="#Family_Mertens"/>
    <livesIn rdf:resource="#Bernau_bei_Berlin"/>
    <parentOf rdf:resource="#Lara_Mertens"/>
    <parentOf rdf:resource="#Paul_Mertens"/>
    <parentOf rdf:resource="#Lila_Mertens"/>
    <ownsTask rdf:resource="#Task_Buy_School_Bag"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Lara_Mertens">
    <rdf:type rdf:resource="#Child"/>
    <rdfs:label>Lara Mertens</rdfs:label>
    <name>Lara Mertens</name>
    <age rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">13</age>
    <dateOfBirth rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2013-03-14</dateOfBirth>
    <memberOfFamily rdf:resource="#Family_Mertens"/>
    <livesIn rdf:resource="#Bernau_bei_Berlin"/>
    <attendsSchool rdf:resource="#Grundschule_Biesenthal"/>
    <siblingOf rdf:resource="#Paul_Mertens"/>
    <siblingOf rdf:resource="#Lila_Mertens"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Paul_Mertens">
    <rdf:type rdf:resource="#Child"/>
    <rdfs:label>Paul Mertens</rdfs:label>
    <name>Paul Mertens</name>
    <age rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">11</age>
    <dateOfBirth rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-01-22</dateOfBirth>
    <memberOfFamily rdf:resource="#Family_Mertens"/>
    <livesIn rdf:resource="#Bernau_bei_Berlin"/>
    <attendsSchool rdf:resource="#Grundschule_Biesenthal"/>
    <siblingOf rdf:resource="#Lara_Mertens"/>
    <siblingOf rdf:resource="#Lila_Mertens"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Lila_Mertens">
    <rdf:type rdf:resource="#Child"/>
    <rdfs:label>Lila Mertens</rdfs:label>
    <name>Lila Mertens</name>
    <age rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</age>
    <dateOfBirth rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-05-09</dateOfBirth>
    <memberOfFamily rdf:resource="#Family_Mertens"/>
    <livesIn rdf:resource="#Bernau_bei_Berlin"/>
    <hasEvent rdf:resource="#Event_Einschulung_Lila_2026"/>
    <siblingOf rdf:resource="#Lara_Mertens"/>
    <siblingOf rdf:resource="#Paul_Mertens"/>
  </owl:NamedIndividual>

  <!-- Individuals: event -->

  <owl:NamedIndividual rdf:about="#Event_Einschulung_Lila_2026">
    <rdf:type rdf:resource="#SchoolStartEvent"/>
    <rdfs:label>Einschulung Lila Mertens</rdfs:label>
    <startDateTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-08-22T10:00:00+02:00</startDateTime>
    <endDateTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-08-22T13:00:00+02:00</endDateTime>
    <takesPlaceAt rdf:resource="#Grundschule_Biesenthal"/>
    <affectsPerson rdf:resource="#Lila_Mertens"/>
    <affectsPerson rdf:resource="#Vera_Mertens"/>
    <affectsPerson rdf:resource="#Christian_Mertens"/>
    <affectsPerson rdf:resource="#Lara_Mertens"/>
    <affectsPerson rdf:resource="#Paul_Mertens"/>
    <createsTask rdf:resource="#Task_Confirm_Ceremony_Time"/>
    <createsTask rdf:resource="#Task_Buy_School_Bag"/>
    <createsTask rdf:resource="#Task_Prepare_Schultuete"/>
    <createsTask rdf:resource="#Task_Plan_Route"/>
    <createsTask rdf:resource="#Task_Organize_Family_Lunch"/>
  </owl:NamedIndividual>

  <!-- Individuals: topics -->

  <owl:NamedIndividual rdf:about="#Topic_School">
    <rdf:type rdf:resource="#Topic"/>
    <rdfs:label>School</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Topic_Logistics">
    <rdf:type rdf:resource="#Topic"/>
    <rdfs:label>Logistics</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Topic_Family_Event">
    <rdf:type rdf:resource="#Topic"/>
    <rdfs:label>Family Event</rdfs:label>
  </owl:NamedIndividual>

  <!-- Individuals: tasks. Labels match the flattened sentence wording. -->

  <owl:NamedIndividual rdf:about="#Task_Confirm_Ceremony_Time">
    <rdf:type rdf:resource="#Task"/>
    <rdfs:label>Confirm ceremony time</rdfs:label>
    <taskStatus>open</taskStatus>
    <urgency>high</urgency>
    <needsOwner rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</needsOwner>
    <hasTopic rdf:resource="#Topic_School"/>
    <dueBefore rdf:resource="#Event_Einschulung_Lila_2026"/>
    <belongsToLoadCluster rdf:resource="#Cluster_Lila_School_Start"/>
    <derivedFromSource rdf:resource="#Source_Parent_Chat_001"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Task_Buy_School_Bag">
    <rdf:type rdf:resource="#Task"/>
    <rdfs:label>Buy school bag</rdfs:label>
    <taskStatus>open</taskStatus>
    <urgency>medium</urgency>
    <needsOwner rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</needsOwner>
    <hasTopic rdf:resource="#Topic_School"/>
    <dueBefore rdf:resource="#Event_Einschulung_Lila_2026"/>
    <belongsToLoadCluster rdf:resource="#Cluster_Lila_School_Start"/>
    <derivedFromSource rdf:resource="#Source_Parent_Chat_001"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Task_Prepare_Schultuete">
    <rdf:type rdf:resource="#Task"/>
    <rdfs:label>Prepare Schultuete</rdfs:label>
    <taskStatus>open</taskStatus>
    <urgency>medium</urgency>
    <needsOwner rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</needsOwner>
    <hasTopic rdf:resource="#Topic_Family_Event"/>
    <dueBefore rdf:resource="#Event_Einschulung_Lila_2026"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Task_Plan_Route">
    <rdf:type rdf:resource="#Task"/>
    <rdfs:label>Plan route</rdfs:label>
    <taskStatus>open</taskStatus>
    <urgency>medium</urgency>
    <needsOwner rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</needsOwner>
    <hasTopic rdf:resource="#Topic_Logistics"/>
    <dueBefore rdf:resource="#Event_Einschulung_Lila_2026"/>
    <belongsToLoadCluster rdf:resource="#Cluster_Lila_School_Start"/>
    <derivedFromSource rdf:resource="#Source_Calendar_Einschulung"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Task_Organize_Family_Lunch">
    <rdf:type rdf:resource="#Task"/>
    <rdfs:label>Organize family lunch</rdfs:label>
    <taskStatus>open</taskStatus>
    <urgency>low</urgency>
    <needsOwner rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</needsOwner>
    <hasTopic rdf:resource="#Topic_Family_Event"/>
    <dueBefore rdf:resource="#Event_Einschulung_Lila_2026"/>
  </owl:NamedIndividual>

  <!-- Individuals: input channels and sources -->

  <owl:NamedIndividual rdf:about="#Channel_Calendar">
    <rdf:type rdf:resource="#InputChannel"/>
    <rdfs:label>Google Calendar</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Channel_School_Message">
    <rdf:type rdf:resource="#InputChannel"/>
    <rdfs:label>School Portal</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Channel_Parent_Chat">
    <rdf:type rdf:resource="#InputChannel"/>
    <rdfs:label>Parent Chat</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Source_Calendar_Einschulung">
    <rdf:type rdf:resource="#SourceRecord"/>
    <rdfs:label>Calendar import: Einschulung Lila</rdfs:label>
    <sourceChannel rdf:resource="#Channel_Calendar"/>
    <rawText>Einschulung Lila, 22.08.2026, 10:00, Grundschule Biesenthal</rawText>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Source_Parent_Chat_001">
    <rdf:type rdf:resource="#SourceRecord"/>
    <rdfs:label>Parent chat note</rdfs:label>
    <sourceChannel rdf:resource="#Channel_Parent_Chat"/>
    <rawText>Christian handles the school bag. Vera confirms the exact time with the school.</rawText>
  </owl:NamedIndividual>

  <!-- Load cluster -->

  <owl:NamedIndividual rdf:about="#Cluster_Lila_School_Start">
    <rdf:type rdf:resource="#LoadCluster"/>
    <rdfs:label>Lila school-start coordination cluster</rdfs:label>
  </owl:NamedIndividual>

</rdf:RDF>


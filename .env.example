## COGNEE

# Backend: "cloud" (default) uses the Cognee cloud REST API below.
COGNEE_MODE=cloud

# see https://platform.cognee.ai (cloud mode only)
COGNEE_API_KEY=
COGNEE_API_BASE_URL=
COGNEE_TENANT=
COGNEE_USER_ID=
COGNEE_BRAIN=


#COGNEE_MODE=local

# Local mode only (COGNEE_MODE=local): the in-process cognee lib calls the LLM
# itself. LLM_API_KEY is required; defaults assume OpenAI. For a non-OpenAI
# provider also set LLM_PROVIDER/LLM_MODEL + EMBEDDING_* (see https://docs.cognee.ai).
LLM_API_KEY=
# LLM_PROVIDER=
# LLM_MODEL=
# EMBEDDING_PROVIDER=
# EMBEDDING_MODEL=
# EMBEDDING_API_KEY=


## FRONTEND BACKEND SETTINGS

# Shared secret the frontend sends as X-API-Key. Unset = open (public repo).
# Set in prod to gate /api/*.
API_KEY=

# Expose /docs, /redoc, /openapi.json. true in dev; leave unset in prod.
DOCS_ENABLED=
